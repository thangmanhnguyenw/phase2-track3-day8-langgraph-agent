# LLM provider (recommended: openai)
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...

# Alternative providers (comment out OPENAI above if switching)
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=AIza...
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: override default model
# LLM_MODEL=gpt-4o-mini

# Optional: real HITL interrupts (default: mock approval)
# LANGGRAPH_INTERRUPT=true

# Optional: persistence backend
CHECKPOINTER=memory
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/langgraph_lab

LOG_LEVEL=INFO
